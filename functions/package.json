{
  "name": "functions",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "build": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "preemulators": "npm run emulators:kill",
    "preemulators:exec": "npm run emulators:kill",
    "emulators": "mkdir -p ../.artifacts/firebase && cd ../.artifacts/firebase && FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID:-tokiwa-template} FIREBASE_STORAGE_BUCKET=${FIREBASE_STORAGE_BUCKET:-${FIREBASE_PROJECT_ID:-tokiwa-template}.appspot.com} firebase --config ../../firebase.functions-test.json emulators:start --project \"${FIREBASE_PROJECT_ID:-tokiwa-template}\" --only auth,firestore,storage",
    "emulators:exec": "mkdir -p ../.artifacts/firebase && cd ../.artifacts/firebase && FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID:-tokiwa-template} FIREBASE_STORAGE_BUCKET=${FIREBASE_STORAGE_BUCKET:-${FIREBASE_PROJECT_ID:-tokiwa-template}.appspot.com} firebase --config ../../firebase.functions-test.json emulators:exec --project \"${FIREBASE_PROJECT_ID:-tokiwa-template}\" --only auth,firestore,storage",
    "emulators:kill": "lsof -ti:8080,9099,9199 | xargs kill -9 2>/dev/null || true; sleep 1",
    "test": "npm run emulators:exec -- 'vitest --config ../../functions/vitest.config.ts run'",
    "test:watch": "npm run emulators:exec -- 'vitest --config ../../functions/vitest.config.ts'",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "npm run emulators:exec -- 'vitest --config ../../functions/vitest.config.ts run --coverage'",
    "serve": "npm run build && mkdir -p ../.artifacts/firebase && cd ../.artifacts/firebase && FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID:-tokiwa-template} firebase --config ../../firebase.json emulators:start --project \"${FIREBASE_PROJECT_ID:-tokiwa-template}\" --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.cjs",
  "dependencies": {
    "@mzsn/firestore": "^1.2.12",
    "@napi-rs/image": "^1.12.0",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260511.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "firebase-functions-test": "^3.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
