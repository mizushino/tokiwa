{
  "name": "hosting",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "tsgo && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report ./.artifacts/playwright/report",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:default": "APP_SITE=default npm run lint",
    "build:default": "APP_SITE=default npm run build",
    "lint:admin": "APP_SITE=admin npm run lint",
    "build:admin": "APP_SITE=admin npm run build"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@lit-labs/router": "^0.1.4",
    "@mzsn/firestore": "^1.2.13",
    "@tailwindcss/vite": "^4.3.1",
    "firebase": "^12.15.0",
    "lit": "^3.3.3",
    "lit-async": "^0.3.3",
    "lit-builder": "^0.1.3",
    "lit-share": "^0.1.3",
    "tailwindcss": "^4.3.1",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "firebase-admin": "^14.1.0",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^7.0.1-rc",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
