{
  "name": "hosting",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "tsgo && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report ./.artifacts/playwright/report",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:default": "APP_SITE=default npm run lint",
    "build:default": "APP_SITE=default npm run build",
    "lint:admin": "APP_SITE=admin npm run lint",
    "build:admin": "APP_SITE=admin npm run build"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@lit-labs/router": "^0.1.4",
    "@mzsn/firestore": "^1.2.11",
    "@tailwindcss/vite": "^4.2.4",
    "firebase": "^12.13.0",
    "lit": "^3.3.2",
    "lit-async": "^0.3.1",
    "lit-builder": "^0.1.1",
    "lit-share": "^0.1.1",
    "tailwindcss": "^4.2.4",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "^7.0.0-dev.20260508.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "firebase-admin": "^13.9.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
